{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!!node_modules", "!!dist", "!!coverage", "!!.cache"],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": "error",
      "suspicious": "error",
      "complexity": "error",
      "performance": "error",
      "security": "error",
      "style": "error",
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 500
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/**/*.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noNodejsModules": "off",
            "useQwikValidLexicalScope": "off"
          }
        }
      }
    },
    {
      "includes": ["src/index.ts", "src/extension/index.ts", "extensions/pi-semsearch.ts", "vitest.config.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          },
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/parsing/cast.ts",
        "src/parsing/language.ts",
        "src/scanner/index.ts",
        "src/scanner/**/*.ts",
        "src/shared/types.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useConsistentTypeDefinitions": "off"
          }
        }
      }
    },
    {
      "includes": ["src/**/*.test.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          },
          "suspicious": {
            "useAwait": "off"
          },
          "style": {
            "noMagicNumbers": "off",
            "useNamingConvention": "off"
          },
          "nursery": {
            "noExcessiveLinesPerFile": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/options/index.ts",
        "src/extension/index.ts",
        "src/extension/**/*.ts",
        "src/retriever/index.ts",
        "src/scanner/index.ts",
        "src/scanner/**/*.ts",
        "src/topology/index.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off"
          }
        }
      }
    },
    {
      "includes": ["src/scanner/index.ts", "src/scanner/**/*.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noAwaitInLoops": "off"
          }
        }
      }
    },
    {
      "includes": ["src/parsing/cast.ts", "src/parsing/fallback.ts", "src/scanner/index.ts", "src/scanner/**/*.ts"],
      "linter": {
        "rules": {
          "complexity": {
            "useMaxParams": "off"
          }
        }
      }
    },
    {
      "includes": ["src/options/index.ts"],
      "linter": {
        "rules": {
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    },
    {
      "includes": ["src/extension/index.ts", "src/extension/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          },
          "suspicious": {
            "useAwait": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/embeddings/openai.ts",
        "src/options/index.ts",
        "src/extension/index.ts",
        "src/extension/**/*.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": {
              "level": "error",
              "options": {
                "strictCase": false
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/parsing/cast.ts",
        "src/parsing/fallback.ts",
        "src/parsing/language.ts",
        "src/embeddings/openai.ts",
        "src/options/index.ts",
        "src/extension/index.ts",
        "src/extension/**/*.ts",
        "src/parsing/range.ts",
        "src/retriever/index.ts",
        "src/scanner/index.ts",
        "src/scanner/**/*.ts",
        "src/store/index.ts",
        "src/topology/index.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useExportsLast": "off"
          }
        }
      }
    }
  ],
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "recommended": true
      }
    }
  }
}
