{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-plugin-cast",
  "version": "0.1.0",
  "description": "Unofficial CAST semantic code search plugin for opencode.",
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikolaiUgelvik/opencode-plugin-cast.git"
  },
  "bugs": {
    "url": "https://github.com/NikolaiUgelvik/opencode-plugin-cast/issues"
  },
  "homepage": "https://github.com/NikolaiUgelvik/opencode-plugin-cast#readme",
  "keywords": [
    "opencode",
    "plugin",
    "semantic-search",
    "code-search",
    "cast"
  ],
  "scripts": {
    "test": "bun test --timeout 30000",
    "typecheck": "tsgo --noEmit",
    "build": "tsc",
    "prepack": "bun run typecheck && bun run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "1.15.12",
    "chokidar": "4.0.3",
    "ignore": "7.0.5",
    "minimatch": "10.0.3",
    "tree-sitter-bash": "0.25.0",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-ruby": "0.23.1",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.25.10",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.2",
    "@types/bun": "1.3.13",
    "@types/node": "24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "typescript": "5.8.2"
  },
  "trustedDependencies": [
    "tree-sitter",
    "tree-sitter-bash",
    "tree-sitter-go",
    "tree-sitter-java",
    "tree-sitter-javascript",
    "tree-sitter-python",
    "tree-sitter-ruby",
    "tree-sitter-rust",
    "tree-sitter-typescript",
    "web-tree-sitter"
  ]
}
